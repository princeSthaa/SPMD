@page
@model SPMD.Pages.Account.SetupCredentialsModel
@{
    ViewData["Title"] = "Setup Your Account";
    Layout = null; // Use clean layout similar to login
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SPMD</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl overflow-hidden">
        <div class="bg-primary p-8 text-white bg-[#001f3f]">
            <h1 class="text-2xl font-bold">First-Time Setup</h1>
            <p class="text-blue-100 mt-2">Please update your credentials to continue.</p>
        </div>
        
        <div class="p-8">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
                    <p class="text-red-700 text-sm">@Model.ErrorMessage</p>
                </div>
            }

            <form method="post" class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">New Username</label>
                    <input asp-for="NewUsername" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">New Password</label>
                    <input asp-for="NewPassword" type="password" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                </div>

                <button type="submit" class="w-full bg-[#001f3f] text-white py-3 rounded-lg font-bold hover:bg-slate-800 transition-colors shadow-lg">
                    Update Credentials
                </button>
            </form>
        </div>
    </div>
</body>
</html>
