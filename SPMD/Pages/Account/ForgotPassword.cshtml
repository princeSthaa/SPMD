@page
@model SPMD.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-xl overflow-hidden">
                <div class="card-header bg-primary text-white text-center py-4">
                    <span class="material-symbols-outlined display-4 mb-2">lock_reset</span>
                    <h3 class="fw-bold mb-0">Recover Password</h3>
                </div>
                <div class="card-body p-5">
                    @if (Model.Message != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm rounded-lg mb-4">
                            <i class="bi bi-check-circle-fill me-2"></i> @Model.Message
                        </div>
                        <div class="text-center">
                            <a asp-page="/Account/Login" class="btn btn-primary rounded-pill px-4">Return to Login</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-4">Enter your registered email address and we'll send you a link to reset your password.</p>
                        
                        <form method="post">
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label small fw-bold text-uppercase tracking-wider text-muted">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Email" class="form-control bg-light border-start-0" placeholder="e.g. name@example.com" required />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">Send Reset Link</button>
                                <a asp-page="/Account/Login" class="btn btn-link text-muted mt-2">Back to Login</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-xl { border-radius: 1.5rem !important; }
    .rounded-lg { border-radius: 1rem !important; }
</style>
