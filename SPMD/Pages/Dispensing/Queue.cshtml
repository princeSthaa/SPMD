@page
@model SPMD.Pages.Dispensing.QueueModel
@{
    ViewData["Title"] = "Dispensing Queue";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="display-6 text-success">Dispensing Queue</h2>
            <p class="text-muted">Process issued prescriptions and verify medications.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Prescription #</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date Issued</th>
                            <th>Items</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingPrescriptions.Any())
                        {
                            @foreach (var p in Model.PendingPrescriptions)
                            {
                                <tr>
                                    <td><code class="text-primary fw-bold">@p.PrescriptionNumber.Substring(0, 8)</code></td>
                                    <td>@p.Patient.FirstName @p.Patient.LastName</td>
                                    <td>Dr. @p.Doctor.LastName</td>
                                    <td>@p.IssuedAt.ToString("g")</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@p.Items.Count items</span>
                                    </td>
                                    <td>
                                        <a asp-page="./Process" asp-route-id="@p.PrescriptionId" class="btn btn-sm btn-success shadow-sm">Process</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <div class="display-4 mb-3">✅</div>
                                    <h5>All prescriptions have been dispensed.</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
