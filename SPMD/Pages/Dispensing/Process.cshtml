@page "{id:int}"
@model SPMD.Pages.Dispensing.ProcessModel
@{
    ViewData["Title"] = "Authorize Dispensing";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-xl overflow-hidden bg-white">
                <div class="card-header bg-secondary-container py-4 px-5 border-bottom border-outline-variant">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary p-2 rounded-lg me-3">
                                <span class="material-symbols-outlined text-white fs-3">dispense</span>
                            </div>
                            <div>
                                <h2 class="h3 mb-0 text-primary fw-bold">Prescription Authorization</h2>
                                <p class="mb-0 text-on-secondary-container small uppercase tracking-wider fw-semibold">PHARMACY DISPENSING UNIT</p>
                            </div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-primary px-3 py-2 fs-6">REF: @Model.Prescription?.PrescriptionNumber</span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert bg-error-container text-on-error-container border-error mb-4"></div>

                        <!-- Patient Context -->
                        <div class="p-4 bg-surface-container-low rounded-xl border border-outline-variant mb-5">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3">@Model.Prescription?.Patient?.FirstName?[0]@Model.Prescription?.Patient?.LastName?[0]</div>
                                        <div>
                                            <h4 class="text-primary fw-bold mb-0">@Model.Prescription?.Patient?.FirstName @Model.Prescription?.Patient?.LastName</h4>
                                            <span class="text-on-surface-variant small uppercase tracking-tighter">Verified Patient ID: #@Model.Prescription?.PatientId</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 text-md-end border-start-md border-outline-variant/30 ps-md-4">
                                    <div class="d-flex align-items-center justify-content-md-end text-on-surface-variant mb-1">
                                        <span class="material-symbols-outlined fs-6 me-2 text-secondary">stethoscope</span>
                                        <span class="small fw-bold">ISSUING DOCTOR:</span>
                                    </div>
                                    <p class="mb-0 text-on-surface fw-semibold">Dr. @Model.Prescription?.Doctor?.FirstName @Model.Prescription?.Doctor?.LastName</p>
                                </div>
                            </div>
                        </div>

                        <div class="clinical-section mb-5">
                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-light">
                                <span class="material-symbols-outlined text-secondary me-2 fs-5">medication</span>
                                <h5 class="text-on-surface fw-bold mb-0 text-uppercase small tracking-widest">Medication Fulfillment Items</h5>
                            </div>

                            @foreach (var item in Model.Prescription?.Items ?? new List<SPMD.Models.PrescriptionItem>())
                            {
                                var activeBatches = item.Medicine?.Batches
                                    .Where(b => b.ExpiryDate > DateTime.UtcNow && b.QuantityAvailable > 0)
                                    .OrderBy(b => b.ExpiryDate)
                                    .ToList() ?? new List<SPMD.Models.MedicineBatch>();
                                
                                var totalAvailable = activeBatches.Sum(b => b.QuantityAvailable);
                                var isShortage = totalAvailable < (double)item.Quantity;

                                <div class="fulfillment-item card mb-4 border-0 shadow-inner-sm bg-surface-container-lowest p-4 rounded-xl border-start border-5 @(isShortage ? "border-error" : "border-success")">
                                    <div class="row align-items-center mb-4">
                                        <div class="col-md-7">
                                            <h5 class="mb-1 text-primary fw-bold">@(item.Medicine?.MedicineName ?? "Unknown Medication")</h5>
                                            <div class="d-flex align-items-center text-on-surface-variant small">
                                                <span class="material-symbols-outlined fs-6 me-1">description</span>
                                                <span><strong>DOSAGE:</strong> @item.Dosage</span>
                                            </div>
                                            <div class="mt-2">
                                                <span class="text-secondary small uppercase fw-bold tracking-wider">Prescribed Quantity:</span>
                                                <span class="badge bg-secondary-container text-primary border-primary ms-2 fs-6">@item.Quantity Units</span>
                                            </div>
                                        </div>
                                        <div class="col-md-5 text-md-end mt-3 mt-md-0">
                                            <div class="form-check form-switch d-inline-flex align-items-center p-3 rounded-lg @(isShortage ? "bg-error-container/20" : "bg-success-container/10")">
                                                <input class="form-check-input me-3" type="checkbox" role="switch" required id="check_@item.PrescriptionItemId">
                                                <label class="form-check-label fw-bold @(isShortage ? "text-error" : "text-success")" for="check_@item.PrescriptionItemId">
                                                    @(isShortage ? "STOCK SHORTAGE" : "IDENTIFIED & VERIFIED")
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="batch-plan p-4 bg-surface-container-low rounded-lg border border-outline-variant">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <div class="d-flex align-items-center">
                                                <span class="material-symbols-outlined text-secondary me-2 fs-5">inventory</span>
                                                <strong class="text-on-surface-variant text-uppercase small tracking-widest">FEFO Selection Strategy</strong>
                                            </div>
                                            <span class="badge @(isShortage ? "bg-error-container text-on-error-container border-error" : "bg-primary-container text-white")">
                                                NET AVAILABLE: @totalAvailable
                                            </span>
                                        </div>
                                        
                                        @if (activeBatches.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm table-borderless mb-0">
                                                    <thead>
                                                        <tr class="text-on-surface-variant small uppercase tracking-tighter border-bottom">
                                                            <th class="py-2">Batch Identification</th>
                                                            <th class="py-2">Expiration</th>
                                                            <th class="py-2 text-end">On Hand</th>
                                                            <th class="py-2 text-end">Allocation</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="font-data-mono small">
                                                        @{
                                                            double remaining = (double)item.Quantity;
                                                            foreach (var batch in activeBatches)
                                                            {
                                                                double deduct = Math.Min(batch.QuantityAvailable, remaining);
                                                                if (deduct <= 0 && remaining <= 0) break;
                                                                <tr>
                                                                    <td class="py-2"><span class="bg-white px-2 py-1 rounded border">@batch.BatchNumber</span></td>
                                                                    <td class="py-2 @(batch.ExpiryDate < DateTime.UtcNow.AddMonths(3) ? "text-error fw-bold" : "text-on-surface")">
                                                                        @batch.ExpiryDate.ToString("MMM yyyy")
                                                                    </td>
                                                                    <td class="py-2 text-end">@batch.QuantityAvailable</td>
                                                                    <td class="py-2 text-end text-primary fw-bold">(-@deduct)</td>
                                                                </tr>
                                                                remaining -= deduct;
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            @if (remaining > 0)
                                            {
                                                <div class="mt-3 p-2 bg-error-container/30 border-error border rounded text-error text-center small fw-bold animate__animated animate__shakeX">
                                                    <span class="material-symbols-outlined fs-6 me-2">error</span>
                                                    INSUFFICIENT STOCK: @remaining UNITS REMAINING
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="text-error fw-bold text-center py-3">
                                                <span class="material-symbols-outlined display-6 mb-2">emergency_home</span><br/>
                                                CRITICAL: ZERO ACTIVE STOCK DETECTED
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Dispensing Authorization -->
                        <div class="clinical-section">
                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-light">
                                <span class="material-symbols-outlined text-secondary me-2 fs-5">assignment_turned_in</span>
                                <h5 class="text-on-surface fw-bold mb-0 text-uppercase small tracking-widest">4. Authorization & Records</h5>
                            </div>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="card bg-white p-4 border-outline-variant shadow-sm h-100">
                                        <label class="form-label fw-bold small text-uppercase text-on-surface-variant mb-2">Dispensing Pharmacist Notes</label>
                                        <textarea class="form-control border-outline-variant" rows="3" placeholder="Document any counseling provided or medication substitutions..."></textarea>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card bg-surface-container-low p-4 border-outline-variant shadow-inner-sm h-100">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="material-symbols-outlined text-primary me-2">verified_user</span>
                                            <span class="fw-bold small text-primary uppercase tracking-wider">Final Verification Checklist</span>
                                        </div>
                                        <ul class="list-unstyled small space-y-2 text-on-surface-variant">
                                            <li class="d-flex align-items-center"><span class="material-symbols-outlined text-success fs-6 me-2">check</span> Right Patient Identified</li>
                                            <li class="d-flex align-items-center"><span class="material-symbols-outlined text-success fs-6 me-2">check</span> Right Drug & Strength</li>
                                            <li class="d-flex align-items-center"><span class="material-symbols-outlined text-success fs-6 me-2">check</span> Allergy Profile Verified</li>
                                            <li class="d-flex align-items-center"><span class="material-symbols-outlined text-success fs-6 me-2">check</span> Expiration Dates Checked</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Controls -->
                        <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top border-outline-variant/30">
                            <a asp-page="./Queue" class="btn btn-outline-secondary px-5 rounded-pill">
                                Return to Queue
                            </a>
                            <button type="submit" class="btn btn-primary px-5 py-3 rounded-pill fw-bold shadow-md d-flex align-items-center">
                                <span class="material-symbols-outlined me-2">inventory_2</span>
                                Finalize & Record Dispensing
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-xl { border-radius: 1.25rem !important; }
    .bg-error-container { background-color: #fef2f2; color: #991b1b; }
    .border-error { border: 1px solid #fecaca; }
    .bg-success-container { background-color: #ecfdf5; color: #065f46; }
    .font-data-mono { font-family: var(--font-family-mono); }
    .avatar-circle {
        width: 48px;
        height: 48px;
        background-color: var(--color-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
    }
    .shadow-inner-sm { box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05); }
    .shadow-md { box-shadow: 0 4px 12px rgba(0, 35, 111, 0.15); }
    .border-start-md { border-left: 0; }
    @@media (min-width: 768px) { .border-start-md { border-left: 1px solid !important; } }
    .uppercase { text-transform: uppercase; }
    .tracking-tighter { letter-spacing: -0.05em; }
    .tracking-widest { letter-spacing: 0.1em; }
</style>
