<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SPMD Clinical</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartPrescriptionAndMedicationDispensingSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-page="/Index">
                    <span class="material-symbols-outlined me-2 text-primary">health_and_safety</span>
                    SPMD <span class="text-secondary ms-1 small fw-normal">Clinical</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Medicines/Search">Medicine Search</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Doctor") || User.IsInRole("Pharmacist"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Inventory/Dashboard">Inventory</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Dispensing/Queue">Dispensing Queue</a>
                                </li>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Patients/Search">Patients</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Pharmacist"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Admin/Users">Manage Users</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Admin/AuditLogs">Audit Logs</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-page="/Account/Profile">
                                    <span class="material-symbols-outlined fs-5 align-middle me-1">account_circle</span>
                                    @User.Identity?.Name
                                </a>
                            </li>
                            <li class="nav-item ms-2">
                                <form method="post" asp-page="/Account/Logout" class="form-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 mt-1">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container content-wrapper">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="notificationToastContainer" style="z-index: 1050">
        <!-- Toasts will be injected here -->
    </div>

    <footer class="border-top py-4 bg-white mt-auto">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center text-muted small">
                <span>&copy; 2026 - SPMD Clinical Precision System</span>
                <div class="d-flex gap-4">
                    <a asp-page="/Privacy" class="text-decoration-none text-muted">Privacy Protocol</a>
                    <span>v1.0.4-stable</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (user, message) {
            showToast(user, message);
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });

        function showToast(user, message) {
            const toastId = 'toast-' + Date.now();
            const toastHtml = `
                <div id="${toastId}" class="toast animate__animated animate__fadeInRight" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header bg-primary text-white">
                        <span class="material-symbols-outlined me-2 fs-6">notifications</span>
                        <strong class="me-auto">${user}</strong>
                        <small>Just now</small>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body border-start border-4 border-primary">
                        ${message}
                    </div>
                </div>
            `;
            
            $('#notificationToastContainer').append(toastHtml);
            const toastElement = document.getElementById(toastId);
            const toast = new bootstrap.Toast(toastElement, { delay: 10000 });
            toast.show();
            
            // Cleanup after toast is hidden
            toastElement.addEventListener('hidden.bs.toast', function () {
                $(this).remove();
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
