@model IEnumerable<SPMD.Models.MedicineAvailabilityDto>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model != null && Model.Any())
    {
        @foreach (var med in Model)
        {
            <div class="col animate__animated animate__fadeIn">
                <div class="card h-100 shadow-sm border-0 medicine-card bg-white p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="card-title text-primary fw-bold mb-1">@med.MedicineName</h5>
                            <span class="text-secondary small fw-medium">ID: #@med.MedicineId</span>
                        </div>
                        @if (med.AvailabilityStatus == "In Stock")
                        {
                            <span class="badge status-in-stock">Available</span>
                        }
                        else if (med.AvailabilityStatus == "Limited Stock")
                        {
                            <span class="badge status-limited">Limited</span>
                        }
                        else
                        {
                            <span class="badge status-out-of-stock">Out of Stock</span>
                        }
                    </div>
                    
                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <span class="material-symbols-outlined text-secondary fs-6 me-2">science</span>
                            <span class="text-on-surface-variant small fw-semibold text-uppercase tracking-wider">Generic Compound</span>
                        </div>
                        <p class="mb-0 text-on-surface">@(string.IsNullOrEmpty(med.GenericName) ? "N/A" : med.GenericName)</p>
                    </div>
                    
                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <span class="material-symbols-outlined text-secondary fs-6 me-2">factory</span>
                            <span class="text-on-surface-variant small fw-semibold text-uppercase tracking-wider">Manufacturer</span>
                        </div>
                        <p class="mb-0 text-on-surface">@(string.IsNullOrEmpty(med.Brand) ? "Generic / Unknown" : med.Brand)</p>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <span class="material-symbols-outlined text-secondary fs-6 me-2">payments</span>
                            <span class="text-on-surface-variant small fw-semibold text-uppercase tracking-wider">Dispensing Price</span>
                        </div>
                        <p class="mb-0 text-primary fw-bold">@med.PricePerUnit.ToString("C2") / Unit</p>
                    </div>

                    <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                        <div class="text-on-surface-variant small">
                            <span class="fw-bold text-primary">@med.TotalQuantity</span> Units in Inventory
                        </div>
                        <span class="material-symbols-outlined text-primary-container fs-5">info</span>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 w-100">
            <div class="card border-0 bg-surface-container-low text-center py-5">
                <span class="material-symbols-outlined text-secondary display-4 mb-3">inventory_2</span>
                <h4 class="text-on-surface mb-2">No matching medicines found</h4>
                <p class="text-on-surface-variant mb-0 px-4">Try refining your search by name, manufacturer, or generic ingredient.</p>
            </div>
        </div>
    }
</div>

<style>
    .medicine-card {
        border-left: 4px solid var(--color-primary) !important;
        border-radius: var(--radius-md) !important;
    }
    .status-in-stock { background-color: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
    .status-limited { background-color: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
    .status-out-of-stock { background-color: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
</style>
