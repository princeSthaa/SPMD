@page
@model SPMD.Pages.Admin.AuditLogsModel
@{
    ViewData["Title"] = "System Audit Logs";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="display-6 text-dark">System Audit Logs</h2>
            <p class="text-muted">Unmodifiable record of all clinical and administrative actions.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small">Action Type</label>
                    <select name="actionFilter" class="form-select">
                        <option value="">-- All Actions --</option>
                        <option value="0">Create</option>
                        <option value="1">Update</option>
                        <option value="3">Dispense</option>
                        <option value="4">Validate</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Entity Search</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by User ID or Entity Name..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Role</th>
                            <th>Action</th>
                            <th>Target</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.AuditLogs)
                        {
                            <tr>
                                <td class="small">@log.Timestamp.ToString("g")</td>
                                <td><span class="badge bg-light text-dark border">ID: @log.PerformedByUserId</span></td>
                                <td>@log.PerformedByRole</td>
                                <td>
                                    <span class="badge @(log.Action == SPMD.Models.AuditAction.Dispense ? "bg-success" : (log.Action == SPMD.Models.AuditAction.Validate ? "bg-info" : "bg-secondary"))">
                                        @log.Action
                                    </span>
                                </td>
                                <td>@log.EntityName (@log.EntityId)</td>
                                <td class="small">@log.Details</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
