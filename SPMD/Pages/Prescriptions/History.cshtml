@page
@model SPMD.Pages.Prescriptions.HistoryModel
@{
    ViewData["Title"] = "Prescription History";
}

<div class="container mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h2 class="display-6 text-primary fw-bold">Prescription Registry</h2>
            <p class="text-muted">Comprehensive historical record of all issued clinical prescriptions.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Patients/Search" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <span class="material-symbols-outlined align-middle me-2">add_circle</span>
                New Prescription
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-xl overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-surface-container-low text-on-surface-variant small uppercase tracking-wider">
                        <tr>
                            <th class="ps-4 py-3">Reference #</th>
                            <th>Patient</th>
                            <th>Medications</th>
                            <th>Date Issued</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (Model.Prescriptions.Any())
                        {
                            @foreach (var p in Model.Prescriptions)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <code class="text-primary fw-bold">@p.PrescriptionNumber.Substring(0, 8)</code>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-on-surface">@p.Patient?.FirstName @p.Patient?.LastName</div>
                                        <div class="text-muted small">ID: #@p.PatientId</div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var item in p.Items)
                                            {
                                                <span class="badge bg-light text-dark border small">@item.Medicine?.MedicineName</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-on-surface">@p.IssuedAt.ToString("MMM dd, yyyy")</div>
                                        <div class="text-muted small">@p.IssuedAt.ToString("t")</div>
                                    </td>
                                    <td>
                                        @if (p.Status == SPMD.Models.PrescriptionStatus.Issued)
                                        {
                                            <span class="badge bg-success-container text-success border-success px-3">Issued</span>
                                        }
                                        else if (p.Status == SPMD.Models.PrescriptionStatus.Dispensed)
                                        {
                                            <span class="badge bg-info-container text-info border-info px-3">Dispensed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-container text-secondary px-3">@p.Status</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-page="/Prescriptions/Download" asp-route-id="@p.PrescriptionId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            View PDF
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <span class="material-symbols-outlined display-1 text-secondary opacity-25">history</span>
                                    <p class="text-muted mt-3">No prescription records found in the registry.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-xl { border-radius: 1rem !important; }
    .bg-success-container { background-color: #f0fdf4; }
    .text-success { color: #166534; }
    .border-success { border: 1px solid #bbf7d0; }
    .bg-info-container { background-color: #f0f9ff; }
    .text-info { color: #075985; }
    .border-info { border: 1px solid #bae6fd; }
</style>